# Required for production builds: full base URL of the API including /api
# (must match how Express mounts routes — see server/src/app.js app.use("/api", ...))
#
# Set this in your host's build environment (Vercel/Netlify/CI), then rebuild.
# Vite inlines import.meta.env.VITE_* at build time; changing it on the host
# without rebuilding does nothing.
#
# Examples:
# VITE_API_URL=https://eventify-api.onrender.com/api
# VITE_API_URL=https://api.yourdomain.com/api

VITE_API_URL=http://localhost:5000/api

# Emergency override (no rebuild): in index.html add an inline script *before*
# src/main.jsx: window.__EVENTIFY_API_URL__="https://your-api.com/api"
