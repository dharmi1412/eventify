NODE_ENV=production
PORT=5000
# Atlas: Database → Connect → Drivers. If you see querySrv ECONNREFUSED locally, use the
# "standard connection string" (mongodb://host:27017,...) instead of mongodb+srv://
MONGODB_URI=mongodb://127.0.0.1:27017/eventify
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/eventify?retryWrites=true&w=majority
# MONGODB_URI=mongodb://127.0.0.1:27017/eventify
# mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
# Optional legacy: CORS now reflects any browser Origin + Helmet CORP is set for
# cross-origin SPAs. You can remove CLIENT_ORIGIN from Render unless you add a
# stricter policy later.
# CLIENT_ORIGIN=http://localhost:5173
ADMIN_EMAIL=admin@eventify.in
