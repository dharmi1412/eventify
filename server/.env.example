NODE_ENV=production
PORT=5000
# Atlas connection string from Database → Connect; include db name if you use one, e.g. ...mongodb.net/eventify?retryWrites=true
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
# Optional legacy: CORS now reflects any browser Origin + Helmet CORP is set for
# cross-origin SPAs. You can remove CLIENT_ORIGIN from Render unless you add a
# stricter policy later.
# CLIENT_ORIGIN=http://localhost:5173
ADMIN_EMAIL=admin@eventify.in
ADMIN_PASSWORD=admin123
SEED_ON_START=false